<?xml version="1.0" encoding="utf-8"?>

<!-- Hauptlayout: Android-Namespace, Material-Namespace, ID des Layouts, Ganze Breite, Ganze Höhe, Elemente untereinander, Abstand zum Rand -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Titel: Breite nach Inhalt, Höhe nach Inhalt, Text anzeigen, Schriftgröße -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="26sp" />

    <!-- Tagesübersicht: Ganze Breite, Höhe nach Inhalt, Abstand nach oben, Text, Schriftgröße -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Übersicht für heute:"
        android:textSize="20sp" />

    <!-- Nächste Einnahme: ID, Ganze Breite, Höhe nach Inhalt, Abstand nach oben, Text -->
    <TextView
        android:id="@+id/textNextMedication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Nächste Einnahme: Keine Daten" />

    <!-- Bestandswarnung: ID, Ganze Breite, Höhe nach Inhalt, Abstand nach oben, Text -->
    <TextView
        android:id="@+id/textStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="Bestandswarnungen: Keine" />

    <!-- Medikament hinzufügen: ID, Ganze Breite, Höhe nach Inhalt, Abstand nach oben, Text -->
    <Button
    android:id="@+id/buttonAddMedication"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="30dp"
    android:text="Medikament hinzufügen" />

    <!-- Medikamente anzeigen: ID, Ganze Breite, Höhe nach Inhalt, Text -->
    <Button
        android:id="@+id/buttonShowMedications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Medikamente anzeigen" />

    <!-- Bestand: ID, Ganze Breite, Höhe nach Inhalt, Text -->
    <Button
        android:id="@+id/buttonStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bestand" />

    <!-- Verlauf: ID, Ganze Breite, Höhe nach Inhalt, Text -->
    <Button
        android:id="@+id/buttonHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verlauf" />

    <!-- Einstellungen: ID, Ganze Breite, Höhe nach Inhalt, Text -->
    <Button
        android:id="@+id/buttonSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Einstellungen" />

    <!-- BottomNavigationView: ID, Ganze Breite, Höhe nach Inhalt, Menü -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
