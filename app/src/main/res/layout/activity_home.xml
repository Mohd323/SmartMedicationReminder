<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Titel -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="26sp" />

    <!-- Einfache Tagesübersicht -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Übersicht für heute:"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/textNextMedication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Nächste Einnahme: Keine Daten" />

    <TextView
        android:id="@+id/textStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="Bestandswarnungen: Keine" />

    <!-- Medikament hinzufügen -->
    <Button
    android:id="@+id/buttonAddMedication"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="30dp"
    android:text="Medikament hinzufügen" />

    <!-- Medikamente anzeigen -->
    <Button
        android:id="@+id/buttonShowMedications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Medikamente anzeigen" />

    <!-- Bestand öffnen -->
    <Button
        android:id="@+id/buttonStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bestand" />

    <!-- Verlauf -->
    <Button
        android:id="@+id/buttonHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verlauf" />

    <!-- Einstellungen -->
    <Button
        android:id="@+id/buttonSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Einstellungen" />

    <!-- Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
